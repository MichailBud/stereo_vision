# Stereo Vision Project Context
# Добавь в ~/.bashrc строку: source /home/michail/BIIS/stereo_vision/.env

# Переменные окружения проекта
export STEREO_VISION_WS="/home/michail/BIIS/stereo_vision"
export ROS_DOMAIN_ID=0

# Алиасы для навигации
alias sv='cd $STEREO_VISION_WS'
alias sv-build='cd $STEREO_VISION_WS && colcon build --symlink-install'
alias sv-source='source $STEREO_VISION_WS/install/setup.bash'
alias sv-clean='cd $STEREO_VISION_WS && rm -rf build/ install/ log/'

# Алиасы для Gazebo
alias sv-gazebo='gazebo --verbose'

# Алиасы для ROS2
alias sv-ros2-topic='ros2 topic list'
alias sv-ros2-node='ros2 node list'

# Функция для инициализации рабочей среды
sv-init() {
    cd $STEREO_VISION_WS
    source /opt/ros/humble/setup.bash
    source install/setup.bash 2>/dev/null || echo "Сначала выполните: colcon build"
    echo "✓ Stereo Vision workspace инициализирован"
    echo "  Путь: $STEREO_VISION_WS"
}

# Информация о проекте при загрузке
sv-info() {
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  Stereo Vision - Курсовой проект                         ║"
    echo "║  Методы локализации, позиционирования и навигации        ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  Тема: Алгоритм оценки положения робота по стереозрению  ║"
    echo "║  Цель: Локализация на основе триангуляции с двух камер   ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  Стек: ROS2 Humble + Gazebo Classic + Ubuntu 22.04       ║"
    echo "║  Робот: Robot Cameron (дифференциальный привод)          ║"
    echo "║  Камеры: Стерео пара (baseline 10см, 640x480, 30Гц)      ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  Топики:                                                 ║"
    echo "║    /stereo/left/image_raw                                ║"
    echo "║    /stereo/right/image_raw                               ║"
    echo "║    /stereo/left/camera_info                              ║"
    echo "║    /stereo/right/camera_info                             ║"
    echo "╚══════════════════════════════════════════════════════════╝"
}

# Автоматическая инициализация при входе в директорию проекта
cd $STEREO_VISION_WS 2>/dev/null && echo "📁 Stereo Vision project directory"
