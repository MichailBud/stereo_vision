<?xml version="1.0"?>
<sdf version="1.7">
  <model name="robot_cameron">
    
    <!-- Base link (chassis) -->
    <link name="chassis">
      <pose>0 0 0.1 0 0 0</pose>
      <inertial>
        <mass>14.7655</mass>
        <inertia>
          <ixx>0.159959</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.159959</iyy>
          <iyz>0</iyz>
          <izz>0.29531</izz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry>
          <cylinder>
            <radius>0.2</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="chassis_visual">
        <geometry>
          <cylinder>
            <radius>0.2</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1.0</ambient>
          <diffuse>0.7 0.7 0.7 1.0</diffuse>
          <specular>0.01 0.01 0.01 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Left wheel -->
    <link name="left_wheel">
      <pose>0 0.13 0.05 1.5707 0 0</pose>
      <inertial>
        <mass>0.184569</mass>
        <inertia>
          <ixx>0.00012151</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00012151</iyy>
          <iyz>0</iyz>
          <izz>0.00023071</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1.0</ambient>
          <diffuse>0.7 0.7 0.7 1.0</diffuse>
          <specular>0.01 0.01 0.01 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="right_wheel">
      <pose>0 -0.13 0.05 1.5707 0 0</pose>
      <inertial>
        <mass>0.184569</mass>
        <inertia>
          <ixx>0.00012151</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00012151</iyy>
          <iyz>0</iyz>
          <izz>0.00023071</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1.0</ambient>
          <diffuse>0.7 0.7 0.7 1.0</diffuse>
          <specular>0.01 0.01 0.01 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Caster ball (front) -->
    <link name="caster_ball">
      <pose>-0.1 0 0.05 0 0 0</pose>
      <inertial>
        <mass>5</mass>
        <inertia>
          <ixx>0.00061523</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00061523</iyy>
          <iyz>0</iyz>
          <izz>0.00061523</izz>
        </inertia>
      </inertial>
      <collision name="caster_ball_collision">
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1</mu>
              <mu2>1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="caster_ball_visual">
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1.0</ambient>
          <diffuse>0.7 0.7 0.7 1.0</diffuse>
          <specular>0.01 0.01 0.01 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Joint: chassis to left wheel -->
    <joint name="chassis_to_left_wheel" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <!-- Joint: chassis to right wheel -->
    <joint name="chassis_to_right_wheel" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <!-- Joint: chassis to caster ball (ball joint) -->
    <joint name="chassis_to_caster_ball" type="ball">
      <parent>chassis</parent>
      <child>caster_ball</child>
      <pose>0 0 0 0 0 0</pose>
    </joint>

    <!-- Stereo Camera Mount -->
    <link name="stereo_camera_mount">
      <pose>0.18 0 0.25 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="mount_collision">
        <geometry>
          <box>
            <size>0.1 0.04 0.03</size>
          </box>
        </geometry>
      </collision>
      <visual name="mount_visual">
        <geometry>
          <box>
            <size>0.1 0.04 0.03</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.3 0.3 0.3 1.0</diffuse>
          <specular>0.3 0.3 0.3 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Left Camera -->
    <link name="left_camera">
      <pose>0.03 0.05 0 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <sensor name="left_camera_sensor" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.0472</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <plugin name="left_camera_plugin" filename="libgazebo_ros_camera.so">
          <frame_name>left_camera_optical_frame</frame_name>
          <camera_info_topic>/stereo/left/camera_info</camera_info_topic>
          <image_topic>/stereo/left/image_raw</image_topic>
        </plugin>
      </sensor>
    </link>

    <!-- Right Camera -->
    <link name="right_camera">
      <pose>0.03 -0.05 0 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <sensor name="right_camera_sensor" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.0472</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <plugin name="right_camera_plugin" filename="libgazebo_ros_camera.so">
          <frame_name>right_camera_optical_frame</frame_name>
          <camera_info_topic>/stereo/right/camera_info</camera_info_topic>
          <image_topic>/stereo/right/image_raw</image_topic>
        </plugin>
      </sensor>
    </link>

    <!-- Joint: mount to chassis -->
    <joint name="mount_to_chassis" type="fixed">
      <parent>chassis</parent>
      <child>stereo_camera_mount</child>
      <pose>0.18 0 0.25 0 0 0</pose>
    </joint>

    <!-- Joint: left camera to mount -->
    <joint name="left_camera_to_mount" type="fixed">
      <parent>stereo_camera_mount</parent>
      <child>left_camera</child>
      <pose>0.03 0.05 0 0 0 0</pose>
    </joint>

    <!-- Joint: right camera to mount -->
    <joint name="right_camera_to_mount" type="fixed">
      <parent>stereo_camera_mount</parent>
      <child>right_camera</child>
      <pose>0.03 -0.05 0 0 0 0</pose>
    </joint>

  </model>
</sdf>
